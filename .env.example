# --- Base de datos ---
# Rol con permisos de ESCRITURA. Solo lo usa el panel /admin y sus API routes.
DATABASE_URL="postgresql://admin_role:CHANGE_ME@host:5432/arcade_signal?sslmode=require"

# Rol con permisos SOLO DE LECTURA (GRANT SELECT únicamente). Lo usa la API pública.
# Ver prisma/README-roles.sql para crear este rol en Postgres.
DATABASE_URL_PUBLIC="postgresql://public_readonly:CHANGE_ME@host:5432/arcade_signal?sslmode=require"

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3000"
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME"

# --- YouTube Data API v3 (solo se usa server-side, nunca llega al cliente) ---
YOUTUBE_API_KEY="CHANGE_ME"

# --- Dominio propio (para CORS / CSP) ---
APP_ORIGIN="https://arcadesignal.example"

# --- Rate limiting (Upstash Redis recomendado en producción/Vercel) ---
UPSTASH_REDIS_REST_URL="CHANGE_ME"
UPSTASH_REDIS_REST_TOKEN="CHANGE_ME"
